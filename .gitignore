# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - only track base structure and specific CLAUDE.md files
groups/*
!groups/main/
!groups/global/
groups/main/*
groups/global/*
!groups/main/CLAUDE.md
!groups/global/CLAUDE.md

# Local overrides (machine-specific, never committed)
groups/*/CLAUDE.local.md

# Secrets — never commit tokens, keys, credentials, or local envs
*.keys.json
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
.netrc
.authinfo
*.token
*_token
*_token.txt
credentials.json
secrets.json
.onecli/
# One-off local scripts (e.g. test-*.mjs, scratch-*.ts)
test-*.mjs
test-*.ts
!**/src/**/test-*.ts
scratch-*
scratch/

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

# Claude Code runtime artifacts (lockfiles, per-machine settings)
.claude/scheduled_tasks.lock
.claude/settings.local.json

agents-sdk-docs
